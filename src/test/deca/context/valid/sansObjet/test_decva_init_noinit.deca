{
    int a = 3;
    int b = 5;
    int c = 7;
    int d = 2;
    boolean r;
    float x;
    float y;

    x = a + b;      // ConvFloat implicite
    y = c - d;      // ConvFloat implicite

    r =
        (
            (x * y > a * c)
            &&
            !((b + d) == a)
        )
        ||
        (
            (x + y > c)
            &&
            (a * d <= b + c)
        );

    println(r);
}