; Main Program
	TSTO #3
	BOV pile_pleine
	ADDSP #3
; start main program
; Main program
; Beginning of main instructions:
	LOAD #3, R3
	STORE R3, 2(GB)
	LOAD #1, R3
	STORE R3, 3(GB)
	LOAD 2(GB), R1
	OPP R1, R1
	LOAD 3(GB), R3
	ADD R3, R1
	BOV overflow_arith
	FLOAT R1, R1
	STORE R1, 1(GB)
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
