; Main Program
	TSTO #2
	BOV pile_pleine
	ADDSP #2
; start main program
; Main program
; Beginning of main instructions:
	LOAD #1, R1
	STORE R1, 1(GB)
	LOAD #2, R1
	STORE R1, 2(GB)
	LOAD #3, R1
	LOAD 1(GB), R2
	MUL R2, R1
	LOAD 2(GB), R2
	LOAD #2, R3
	QUO R3, R2
	SUB R2, R1
	STORE R1, 1(GB)
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
; end main program
