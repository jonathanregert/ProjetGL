; Main Program
	TSTO #4
	BOV pile_pleine
	ADDSP #4
; start main program
; Main program
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
; Passe1 table de méthode : A base=3(GB) taille=1
; Passe1 table de méthode : B base=4(GB) taille=1
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LEA 3(GB), R0
	STORE R0, 4(GB)
; Beginning of main instructions:
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.A:
; init.A (this dans R1)
	TSTO #1
	BOV pile_pleine
	PUSH R3
	POP R3
	BSR init.Object
	POP R3
	RTS
init.B:
; init.B (this dans R1)
	TSTO #1
	BOV pile_pleine
	PUSH R3
	POP R3
	BSR init.A
	POP R3
	RTS
; Code des méthodes de la classe A
; Code des méthodes de la classe B
; end main program
