// Description :
//    Redéfinition d'une méthode avec une signature différente (nombre de paramètres).
//
// Resultats :
//    Erreur contextuelle
//    Ligne 15 : Signature pas convenable en override avec la super classe

class A {
    int f(int x) {
        return x;
    }
}

class B extends A {
    int f() {
        return 0;
    }
}

{
}

