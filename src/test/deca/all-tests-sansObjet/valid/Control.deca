// Description :
// Stress du flot de contrôle : imbrications profondes if/while/blocs
// Test portées, NoInitialization, Assign tardifs, expressions mixtes
//
// Resultats :
// Affiche une valeur finale et termine

{
    int base = 2;
    int x;
    int y = 3;
    int z;
    boolean go = true;
    int i = 3;
    int j;
    int tmp;

    x = base + y;
    z = 0;

    
    while (i > 0) {
        j = i + 1;
        while (j > 0) {
            if ((i + j) > (base * 2)) {
                z = z + (i * j) - (base + y);
            } else {
                z = z - (j - i);
            }

            // bloc interne + assign tardif
            
            tmp = (z + i) - (j * base);
            if (tmp < 0) {
                    go = go && true;
                } else {
                    go = go && (tmp != 0);
                }

            j = j - 1;
        }
        i = i - 1;
    }

    print("z=");
    println(z);
    print("go=");
    println(go);
}