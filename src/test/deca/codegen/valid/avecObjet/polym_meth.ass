; start main program
; Passe1 table de méthode : Animal base=3(GB) taille=3
; Passe1 table de méthode : Chien base=6(GB) taille=3
; Beginning of main instructions:
	TSTO #12	; Main Program
	BOV pile_pleine
	ADDSP #11
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.Animal.crier, R0
	STORE R0, 5(GB)
	LEA 3(GB), R0
	STORE R0, 6(GB)
	LOAD 4(GB), R0
	STORE R0, 7(GB)
	LOAD 5(GB), R0
	STORE R0, 8(GB)
	LOAD code.Chien.crier, R0
	STORE R0, 8(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	NEW #1, R3
	BOV tas_plein
	LEA 3(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.Animal
	POP R3
	STORE R3, 9(GB)
	NEW #1, R3
	BOV tas_plein
	LEA 6(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.Chien
	POP R3
	STORE R3, 10(GB)
	NEW #1, R3
	BOV tas_plein
	LEA 6(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.Chien
	POP R3
	STORE R3, 11(GB)
	ADDSP #1
	LOAD 9(GB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #1
	ADDSP #1
	LOAD 10(GB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #1
	ADDSP #1
	LOAD 11(GB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #1
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.Animal:
; init.Animal (this = -2(LB))
	RTS
init.Chien:
; init.Chien (this = -2(LB))
	RTS
; Code des méthodes de la classe Animal
code.Animal.crier:
; Méthode Animal.crier
	TSTO #1
	BOV pile_pleine
	PUSH R3
	WSTR "Je suis un Animal"
	WNL
	BRA fin.Animal.crier
fin.Animal.crier:
	POP R3
	RTS
; Code des méthodes de la classe Chien
code.Chien.crier:
; Méthode Chien.crier
	TSTO #1
	BOV pile_pleine
	PUSH R3
	WSTR "Je suis un Chien"
	WNL
	BRA fin.Chien.crier
fin.Chien.crier:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
tas_plein:
	WSTR "Erreur : allocation impossible, tas plein"
	WNL
	ERROR
dereferencement_null:
	WSTR "Erreur : dereferencement de null"
	WNL
	ERROR
; end main program
