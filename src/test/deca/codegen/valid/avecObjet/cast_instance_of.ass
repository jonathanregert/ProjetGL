; start main program
; Passe1 table de méthode : A base=3(GB) taille=3
; Passe1 table de méthode : B base=6(GB) taille=4
; Beginning of main instructions:
	TSTO #14	; Main Program
	BOV pile_pleine
	ADDSP #13
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.A.printName, R0
	STORE R0, 5(GB)
	LEA 3(GB), R0
	STORE R0, 6(GB)
	LOAD 4(GB), R0
	STORE R0, 7(GB)
	LOAD 5(GB), R0
	STORE R0, 8(GB)
	LOAD code.B.printName, R0
	STORE R0, 8(GB)
	LOAD code.B.specifiqueB, R0
	STORE R0, 9(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	NEW #1, R3
	BOV tas_plein
	LEA 3(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.A
	POP R3
	STORE R3, 10(GB)
	NEW #1, R3
	BOV tas_plein
	LEA 6(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.B
	POP R3
	STORE R3, 11(GB)
	LOAD 11(GB), R1
	STORE R1, 12(GB)
	ADDSP #1
	LOAD 12(GB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #1
	LOAD 12(GB), R1
	CMP #null, R1
	BEQ instanceof_false_1
	LOAD 0(R1), R1
instanceof_loop_1:
	CMP #null, R1
	BEQ instanceof_false_1
	CMP 6(GB), R1
	BEQ instanceof_true_1
	LOAD 0(R1), R1
	BRA instanceof_loop_1
instanceof_true_1:
	LOAD #1, R1
	BRA instanceof_end_1
instanceof_false_1:
	LOAD #0, R1
instanceof_end_1:
	CMP #0, R1
	BEQ else_0
	LOAD 12(GB), R1
	STORE R1, 13(GB)
	ADDSP #1
	LOAD 13(GB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 3(R2)
	SUBSP #1
	BRA endif_0
else_0:
endif_0:
	LOAD #null, R1
	STORE R1, 10(GB)
	LOAD 10(GB), R1
	STORE R1, 11(GB)
	WSTR "null cast ok"
	WNL
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.A:
; init.A (this = -2(LB))
	RTS
init.B:
; init.B (this = -2(LB))
	RTS
; Code des méthodes de la classe A
code.A.printName:
; Méthode A.printName
	TSTO #1
	BOV pile_pleine
	PUSH R3
	WSTR "A"
	WNL
	BRA fin.A.printName
fin.A.printName:
	POP R3
	RTS
; Code des méthodes de la classe B
code.B.printName:
; Méthode B.printName
	TSTO #1
	BOV pile_pleine
	PUSH R3
	WSTR "B"
	WNL
	BRA fin.B.printName
fin.B.printName:
	POP R3
	RTS
code.B.specifiqueB:
; Méthode B.specifiqueB
	TSTO #1
	BOV pile_pleine
	PUSH R3
	WSTR "C'est un B"
	WNL
	BRA fin.B.specifiqueB
fin.B.specifiqueB:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
tas_plein:
	WSTR "Erreur : allocation impossible, tas plein"
	WNL
	ERROR
dereferencement_null:
	WSTR "Erreur : dereferencement de null"
	WNL
	ERROR
; end main program
