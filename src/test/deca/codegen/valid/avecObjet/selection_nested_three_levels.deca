// Description :
//    Sélection imbriquée de champ sur trois niveaux d'objets (a.b.c.z).
//
// Resultats :
//    Affiche : 10

class C {
    int z;
}

class B {
    C c;
}

class A {
    B b;
}

{
    A a = new A();
    a.b = new B();
    a.b.c = new C();
    a.b.c.z = 10;
    println(a.b.c.z);
}

