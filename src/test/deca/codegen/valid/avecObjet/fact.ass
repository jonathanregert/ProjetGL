; start main program
; Passe1 table de méthode : Math base=3(GB) taille=3
; Beginning of main instructions:
	TSTO #8	; Main Program
	BOV pile_pleine
	ADDSP #6
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.Math.fact, R0
	STORE R0, 5(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	NEW #1, R3
	BOV tas_plein
	LEA 3(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.Math
	POP R3
	STORE R3, 6(GB)
	ADDSP #2
	LOAD 6(GB), R1
	STORE R1, 0(SP)
	LOAD #5, R1
	STORE R1, -1(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #2
	LOAD R0, R1
	WINT
	WNL
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.Math:
; init.Math (this = -2(LB))
	RTS
; Code des méthodes de la classe Math
code.Math.fact:
; Méthode Math.fact
	TSTO #5
	BOV pile_pleine
	PUSH R3
	LOAD -3(LB), R1
	LOAD #1, R3
	CMP R3, R1
	SLE R1
	CMP #0, R1
	BEQ else_0
	LOAD #1, R1
	LOAD R1, R0
	BRA fin.Math.fact
	BRA endif_0
else_0:
	LOAD -3(LB), R1
	PUSH R1
	ADDSP #2
	LOAD -2(LB), R1
	STORE R1, 0(SP)
	LOAD -3(LB), R1
	PUSH R1
	LOAD #1, R1
	POP R2
	SUB R1, R2
	BOV overflow_arith
	LOAD R2, R1
	STORE R1, -1(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #2
	LOAD R0, R1
	LOAD R1, R3
	POP R2
	MUL R3, R2
	BOV overflow_arith
	LOAD R2, R1
	LOAD R1, R0
	BRA fin.Math.fact
endif_0:
fin.Math.fact:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
tas_plein:
	WSTR "Erreur : allocation impossible, tas plein"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
dereferencement_null:
	WSTR "Erreur : dereferencement de null"
	WNL
	ERROR
; end main program
