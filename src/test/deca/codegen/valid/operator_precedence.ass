; Main Program
	TSTO #2
	BOV pile_pleine
	ADDSP #2
; start main program
; Main program
; Beginning of main instructions:
	LOAD #1, R3
	LOAD #2, R4
	PUSH R4
	LOAD #3, R4
	POP R2
	MUL R4, R2
	BOV overflow_arith
	LOAD R2, R4
	ADD R4, R3
	BOV overflow_arith
	LOAD #4, R4
	PUSH R4
	LOAD #2, R4
	POP R2
	CMP #0, R4
	BEQ division_par_zero
	QUO R4, R2
	BOV overflow_arith
	LOAD R2, R4
	SUB R4, R3
	BOV overflow_arith
	STORE R3, 1(GB)
	LOAD 1(GB), R1
	WINT
	WNL
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
division_par_zero:
	WSTR "Erreur : divion entiere par zero"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
