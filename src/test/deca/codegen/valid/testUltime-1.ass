; Main Program
	TSTO #4
	BOV pile_pleine
	ADDSP #4
; start main program
; Main program
; Beginning of main instructions:
	LOAD #3, R3
	STORE R3, 1(GB)
	LOAD #2, R3
	STORE R3, 2(GB)
	LOAD #7, R3
	STORE R3, 3(GB)
	LOAD 1(GB), R1
	LOAD 2(GB), R3
	LOAD 3(GB), R4
	ADD R4, R3
	BOV overflow_arith
	ADD R3, R1
	BOV overflow_arith
	STORE R1, 4(GB)
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
