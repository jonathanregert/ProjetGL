; Main Program
	TSTO #2
	BOV pile_pleine
	ADDSP #2
; start main program
; Main program
; Beginning of main instructions:
	RINT
	STORE R1, 1(GB)
	LOAD #0x1.0p-1, R1
	LOAD 1(GB), R3
	PUSH R3
	LOAD 1(GB), R3
	POP R2
	MUL R3, R2
	BOV overflow_arith
	LOAD R2, R3
	FLOAT R3, R3
	MUL R3, R1
	BOV overflow_arith
	WFLOAT
	WNL
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
