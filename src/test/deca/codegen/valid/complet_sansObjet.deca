// Description :
// Programme de test grammaticale Deca SANS OBJET.
// Ce test exerce de façon intensive toutes les règles du langage sans objet :
// - bloc principal
// - déclarations simples et multiples
// - initialisation et non-initialisation
// - affectations imbriquées
// - priorités opérateurs arithmétiques
// - opérateurs de comparaison
// - opérateurs booléens (&&, ||, !)
// - expressions unaires (-)
// - if / else if / else
// - while
// - print / println / printx / printlnx
// - cast explicite
// - littéraux int, float, string, true, false, null
// - listes d’expressions
//
// Resultats :
// Le programme affiche des valeurs cohérentes et se termine sans erreur.

{
    // --------------------------------
    // Déclarations
    // --------------------------------
    int a = 3, b = 7, c;
    int i = 0, j, acc = 0;
    int k;
    float f = 2.5, g, h;
    boolean ok = true, flag = false;
    boolean cond;

    // --------------------------------
    // Affectations complexes + casts
    // --------------------------------
    c = -a + (b * (a + 2)) - (b / (a + 1));

    g = (float)(c) + (float)(a + b) * 2.0;
    h = (float)(c * (a - b)) / (float)(a + 1);

    print("c = ");
    println(c);
    print("g = ");
    println(g);
    print("h = ");
    println(h);

    // --------------------------------
    // Cast float -> int
    // --------------------------------
    k = (int)(g);
    j = (int)(h + 3.7);

    print("k = ");
    println(k);
    print("j = ");
    println(j);

    // --------------------------------
    // Cast imbriqués
    // --------------------------------
    k = (int)((float)(a + b) * 1.5);

    print("k (nested cast) = ");
    println(k);

    // --------------------------------
    // Booléens, comparaisons et casts
    // --------------------------------
    cond = !((int)(g) < (int)(h)) || ((int)(f) == 2 && b != 0);

    print("cond = ");
    println(cond);

    // --------------------------------
    // if / else if / else
    // --------------------------------
    if ((int)(g) > (int)(h)) {
        println("g > h");
    } else if ((int)(g) == (int)(h)) {
        println("g == h");
    } else {
        println("g < h");
    }

    // --------------------------------
    // while avec cast dans la condition
    // --------------------------------
    while ((int)(f) < 5) {
        acc = acc + (int)(f);
        f = f + 1.0;
    }

    print("acc = ");
    println(acc);

    // --------------------------------
    // Affectations imbriquées avec cast
    // --------------------------------
    j = a = (int)((float)(b) * 1.0);

    print("a = ");
    println(a);
    print("b = ");
    println(b);
    print("j = ");
    println(j);

    // --------------------------------
    // Listes d'expressions avec casts
    // --------------------------------
    print("values: ");
    print(
        (int)(g), ", ",
        (float)(a), ", ",
        (int)((float)(c) / 2.0)
    );
    println();

    // --------------------------------
    // printx / printlnx
    // --------------------------------
    printx("acc (hex) = ");
    printlnx(acc);

    // --------------------------------
    // Expressions booléennes finales
    // --------------------------------
    flag = false;
    ok = !flag && ((int)(f) >= 5) || false;

    print("ok = ");
    println(ok);
}