// Description :
//    Comparaisons d'entiers et structure conditionnelle (if/else) dans une boucle.
//
// Resultats :
// Affiche :
// 0
// 1
// C'est deux
// 3
// 4

{
   int x = 0;
   while (x < 5) {
      if (x == 2) {
         println("C'est deux");
      } else {
         println(x);
      }
      x = x + 1;
   }
}