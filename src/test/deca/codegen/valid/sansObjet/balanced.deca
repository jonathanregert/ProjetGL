// Description :
// Arbre équilibré arithmétique + logique
// Conversion implicite int -> float (ConvFloat)
//
// Resultats :
// true affiché

{
    int a = 3;
    int b = 5;
    int c = 7;
    int d = 2;

    float x = a + b;
    float y = c - d;

    boolean r;

    r =
        (
            (x * y > a * c)
            &&
            !((b + d) == a)
        )
        ||
        (
            (x + y > c)
            &&
            (a * d <= b + c)
        );

    println(r);
}