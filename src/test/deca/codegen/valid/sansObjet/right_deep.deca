// Description :
// Arbre très déséquilibré à droite
// Court-circuit OR + ConvFloat implicite
//
// Resultats :
// true affiché

{
    int a = 10;
    int b = 5;
    int z = 0;

    float x = a + b;   // ConvFloat implicite

    boolean r;

    r =
        (x > 12.0)
        ||
        (
            (a + (b * (2 + (3 * (4 + 5))))) > 0
            &&
            ((a / z) > 1)
        );

    println(r);
}