// Description :
// Programme extrême sans objet mixant la plupart des nœuds codegen
// DeclVar, Initialization, Assign, IfThenElse, While, Print/Println,
// OpArith/OpCmp/OpBool, UnaryMinus, Not, ConvFloat, Identifier, literals
//
// Resultats :
// Affiche des lignes cohérentes et termine sans erreur

{
    int a = 3;
    int b = 7;
    int c;
    float f = 2.5;
    float g;
    boolean ok = true;
    boolean flag;
    int i = 4;
    int j;
    int acc = 0;

    c = -a + (b * (a + 2)) - (b / (a + 1));

    g = c + f * 2.0;

    print("c=");
    println(c);
    print("g=");
    println(g);

    flag = (c > 0) && !(a > b) || (g >= 0.0);
    if (flag) {
        println("branch:T");
        ok = ok && true;
    } else {
        println("branch:F");
        ok = false;
    }
    

    while (i > 0 && ok) {
        j = i;
        while (j > 0) {
            acc = acc + (i + j) * (i - 1) - (j * 2);
            j = j - 1;
        }
        i = i - 1;
    }

    print("acc=");
    println(acc);
}