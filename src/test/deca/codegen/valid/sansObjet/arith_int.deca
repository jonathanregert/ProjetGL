// Description :
// Test des opérations arithmétiques entières : ADD, SUB, MUL, DIV
// Vérifie le calcul correct et l'ordre des opérations.
//
// Resultats :
// 15, 5, 50, 2 affichés
{
    int x = 10;
    int y = 5;
    int z;
    
    z = x + y;
    print(z);
    z = x - y;
    print(z);
    z = x * y;
    print(z);
    z = x / y;
    print(z);
}
