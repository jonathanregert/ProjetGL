; Main Program
	TSTO #3
	BOV pile_pleine
	ADDSP #3
; start main program
; Main program
; Beginning of main instructions:
	LOAD #4, R3
	STORE R3, 1(GB)
	LOAD #2, R3
	STORE R3, 2(GB)
	LOAD 1(GB), R1
	LOAD 2(GB), R3
	MUL R3, R1
	BOV overflow_arith
	LOAD #3, R3
	SUB R3, R1
	BOV overflow_arith
	LOAD 2(GB), R3
	LOAD #1, R4
	ADD R4, R3
	BOV overflow_arith
	CMP R3, R1
	SGT R1
	STORE R1, 3(GB)
	LOAD 3(GB), R1
	WINT
	WNL
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
