; Main Program
	TSTO #3
	BOV pile_pleine
	ADDSP #3
; start main program
; Main program
; Beginning of main instructions:
	LOAD #7, R1
	STORE R1, 1(GB)
	LOAD #10, R1
	STORE R1, 2(GB)
	LOAD 1(GB), R1
	LOAD 2(GB), R2
	CMP R2, R1
	SGT R1
	CMP #0, R1
	BEQ else_0
	LOAD 1(GB), R1
	STORE R1, 3(GB)
	BRA endif_0
else_0:
	LOAD 2(GB), R1
	LOAD #0, R2
	CMP R2, R1
	SGT R1
	CMP #0, R1
	BEQ else_1
	LOAD 2(GB), R1
	STORE R1, 3(GB)
	BRA endif_1
else_1:
	LOAD #0, R1
	STORE R1, 3(GB)
endif_1:
endif_0:
	LOAD 3(GB), R1
	WINT
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
; end main program
