; Main Program
	TSTO #3
	BOV pile_pleine
	ADDSP #3
; start main program
; Main program
; Beginning of main instructions:
	LOAD #0, R3
	STORE R3, 1(GB)
	LOAD #1, R3
	PUSH R3
	LOAD #0, R3
	POP R2
	CMP #0, R3
	BEQ division_par_zero
	QUO R3, R2
	BOV overflow_arith
	LOAD R2, R3
	PUSH R3
	LOAD #0, R3
	POP R2
	CMP R3, R2
	SEQ R3
	STORE R3, 2(GB)
	LOAD 1(GB), R1
	CMP #0, R1
	BEQ bool_sc_0
	LOAD 2(GB), R1
	BRA bool_end_0
bool_sc_0:
	LOAD #0, R1
bool_end_0:
	WINT
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
division_par_zero:
	WSTR "Erreur : divion entiere par zero"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
