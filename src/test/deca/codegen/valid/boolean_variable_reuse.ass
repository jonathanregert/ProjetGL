; Main Program
	TSTO #2
	BOV pile_pleine
	ADDSP #2
; start main program
; Main program
; Beginning of main instructions:
	LOAD #3, R3
	STORE R3, 2(GB)
	LOAD 2(GB), R1
	LOAD #0, R3
	CMP R3, R1
	SGT R1
	STORE R1, 1(GB)
	LOAD 1(GB), R1
	CMP #0, R1
	BEQ else_0
	LOAD #1, R1
	WINT
	WNL
	BRA endif_0
else_0:
	LOAD #0, R1
	WINT
	WNL
endif_0:
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
; end main program
