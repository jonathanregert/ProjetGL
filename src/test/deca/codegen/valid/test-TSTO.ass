; Main Program
	TSTO #4
	BOV pile_pleine
	ADDSP #4
; start main program
; Main program
; Beginning of main instructions:
	LOAD #1, R1
	STORE R1, 1(GB)
	LOAD #2, R1
	STORE R1, 2(GB)
	LOAD 1(GB), R1
	LOAD 2(GB), R3
	LOAD 1(GB), R4
	PUSH R4
	LOAD 2(GB), R4
	POP R2
	ADD R4, R2
	BOV overflow_arith
	LOAD R2, R4
	MUL R4, R3
	BOV overflow_arith
	ADD R3, R1
	BOV overflow_arith
	STORE R1, 3(GB)
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
