; Main Program
	TSTO #1
	BOV pile_pleine
	ADDSP #1
; start main program
; Main program
; Beginning of main instructions:
	LOAD #1, R3
	STORE R3, 1(GB)
	LOAD 1(GB), R1
	CMP #0, R1
	BNE bool_sc_0
	LOAD #1, R1
	LOAD #0, R3
	CMP #0, R3
	BEQ division_par_zero
	QUO R3, R1
	BOV overflow_arith
	LOAD #0, R3
	CMP R3, R1
	SEQ R1
	BRA bool_end_0
bool_sc_0:
	LOAD #1, R1
bool_end_0:
	WINT
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
division_par_zero:
	WSTR "Erreur : divion entiere par zero"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
