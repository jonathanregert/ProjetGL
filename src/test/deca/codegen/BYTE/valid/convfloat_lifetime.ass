; Main Program
	TSTO #3
	BOV pile_pleine
	ADDSP #3
; start main program
; Main program
; Beginning of main instructions:
	LOAD #3, R3
	STORE R3, 1(GB)
	LOAD #2, R3
	STORE R3, 2(GB)
	LOAD 1(GB), R1
	LOAD 2(GB), R3
	ADD R3, R1
	BOV overflow_arith
	FLOAT R1, R1
	STORE R1, 3(GB)
	LOAD 3(GB), R1
	LOAD #2, R3
	FLOAT R3, R3
	MUL R3, R1
	BOV overflow_arith
	STORE R1, 3(GB)
	LOAD 3(GB), R1
	LOAD #5, R3
	FLOAT R3, R3
	CMP #0x0.0p0, R3
	BEQ division_par_zero_float
	DIV R3, R1
	BOV overflow_arith
	STORE R1, 3(GB)
	LOAD 3(GB), R1
	WFLOAT
	WNL
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
division_par_zero_float:
	WSTR "Erreur : division par 0.0"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
