; Main Program
	TSTO #3
	BOV pile_pleine
	ADDSP #3
; start main program
; Main program
; Beginning of main instructions:
	LOAD #3, R3
	STORE R3, 1(GB)
	LOAD #5, R3
	STORE R3, 2(GB)
	LOAD 1(GB), R1
	LOAD 2(GB), R3
	ADD R3, R1
	BOV overflow_arith
	LOAD #10, R3
	CMP R3, R1
	SGT R1
	CMP #0, R1
	BNE bool_sc_0
	LOAD 1(GB), R1
	LOAD 2(GB), R3
	MUL R3, R1
	BOV overflow_arith
	LOAD #20, R3
	CMP R3, R1
	SLT R1
	BRA bool_end_0
bool_sc_0:
	LOAD #1, R1
bool_end_0:
	CMP #0, R1
	SEQ R1
	STORE R1, 3(GB)
	LOAD 3(GB), R1
	WINT
	WNL
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
