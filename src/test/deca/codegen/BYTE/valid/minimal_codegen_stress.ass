; Main Program
	TSTO #4
	BOV pile_pleine
	ADDSP #4
; start main program
; Main program
; Beginning of main instructions:
	LOAD #1, R3
	STORE R3, 1(GB)
	LOAD #2, R3
	STORE R3, 2(GB)
	LOAD #3, R3
	STORE R3, 3(GB)
	LOAD 1(GB), R1
	LOAD 2(GB), R3
	ADD R3, R1
	BOV overflow_arith
	LOAD 3(GB), R3
	CMP R3, R1
	SGT R1
	CMP #0, R1
	BEQ bool_sc_0
	LOAD 3(GB), R1
	LOAD 2(GB), R3
	SUB R3, R1
	BOV overflow_arith
	LOAD 1(GB), R3
	CMP R3, R1
	SEQ R1
	BRA bool_end_0
bool_sc_0:
	LOAD #0, R1
bool_end_0:
	STORE R1, 4(GB)
	LOAD 4(GB), R1
	WINT
	WNL
	HALT
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
