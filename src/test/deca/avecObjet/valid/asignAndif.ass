; start main program
; Beginning of main instructions:
	TSTO #3	; Main Program
	BOV pile_pleine
	ADDSP #3
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	LOAD #3, R3
	STORE R3, 3(GB)
	LOAD 3(GB), R1
	LOAD #5, R3
	CMP R3, R1
	SLT R1
	CMP #0, R1
	BEQ else_0
	LOAD #12, R1
	STORE R1, 3(GB)
	LOAD 3(GB), R1
	WINT
	BRA endif_0
else_0:
	WSTR "faux"
endif_0:
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
; end main program
