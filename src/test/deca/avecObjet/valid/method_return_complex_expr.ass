; start main program
; Passe1 table de méthode : Z base=3(GB) taille=3
	TSTO #5	; Main Program
	BOV pile_pleine
	ADDSP #5
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.Z.compute, R0
	STORE R0, 5(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.Z:
; init.Z (this = -2(LB))
	RTS
; Code des méthodes de la classe Z
code.Z.compute:
; Méthode Z.compute
	TSTO #3
	BOV pile_pleine
	PUSH R3
	LOAD -3(LB), R1
	PUSH R1
	LOAD -4(LB), R3
	POP R2
	MUL R3, R2
	BOV overflow_arith
	LOAD R2, R1
	PUSH R1
	LOAD -3(LB), R3
	PUSH R3
	LOAD -4(LB), R3
	POP R2
	SUB R3, R2
	BOV overflow_arith
	LOAD R2, R3
	POP R2
	ADD R3, R2
	BOV overflow_arith
	LOAD R2, R1
	LOAD R1, R0
	BRA fin.Z.compute
fin.Z.compute:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
