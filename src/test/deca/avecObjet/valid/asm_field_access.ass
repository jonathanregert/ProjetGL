; start main program
; Passe1 table de méthode : Box base=3(GB) taille=4
; Beginning of main instructions:
	TSTO #9	; Main Program
	BOV pile_pleine
	ADDSP #7
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.Box.setVal, R0
	STORE R0, 5(GB)
	LOAD code.Box.getValAsm, R0
	STORE R0, 6(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	NEW #2, R3
	BOV tas_plein
	LEA 3(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.Box
	POP R3
	STORE R3, 7(GB)
	ADDSP #2
	LOAD 7(GB), R1
	STORE R1, 0(SP)
	LOAD #99, R1
	STORE R1, -1(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #2
	WSTR "Val: "
	ADDSP #1
	LOAD 7(GB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 3(R2)
	SUBSP #1
	LOAD R0, R1
	WINT
	WNL
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.Box:
; init.Box (this = -2(LB))
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD -2(LB), R2
	LOAD #0, R0
	STORE R0, 1(R2)
	POP R3
	RTS
; Code des méthodes de la classe Box
code.Box.setVal:
; Méthode Box.setVal
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD -3(LB), R1
	LOAD -2(LB), R2
	CMP #null, R2
	BEQ dereferencement_null
	STORE R1, 1(R2)
	BRA fin.Box.setVal
fin.Box.setVal:
	POP R3
	RTS
code.Box.getValAsm:
; Méthode ASM code.Box.getValAsm
"LOAD -2(LB), R1 \n LOAD 1(R1), R0 \n RTS"
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
tas_plein:
	WSTR "Erreur : allocation impossible, tas plein"
	WNL
	ERROR
dereferencement_null:
	WSTR "Erreur : dereferencement de null"
	WNL
	ERROR
; end main program
