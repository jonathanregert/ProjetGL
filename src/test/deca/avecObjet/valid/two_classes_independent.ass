; start main program
; Passe1 table de méthode : A base=3(GB) taille=2
; Passe1 table de méthode : B base=5(GB) taille=2
; Beginning of main instructions:
	TSTO #6	; Main Program
	BOV pile_pleine
	ADDSP #6
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LEA 1(GB), R0
	STORE R0, 5(GB)
	LOAD 2(GB), R0
	STORE R0, 6(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.A:
; init.A (this = -2(LB))
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD -2(LB), R2
	LOAD #0, R0
	STORE R0, 1(R2)
	POP R3
	RTS
init.B:
; init.B (this = -2(LB))
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD -2(LB), R2
	LOAD #0, R0
	STORE R0, 1(R2)
	POP R3
	RTS
; Code des méthodes de la classe A
; Code des méthodes de la classe B
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
; end main program
