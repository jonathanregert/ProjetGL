// Description:
//    Test basique du polymorphisme (override).
//
// Resultats:
//    Je suis un Animal
//    Je suis un Chien
//    Je suis un Chien

class Animal {
    void crier() { println("Je suis un Animal"); }
}

class Chien extends Animal {
    void crier() { println("Je suis un Chien"); }
}

{
    Animal a1 = new Animal();
    Animal a2 = new Chien();
    Chien c = new Chien();

    a1.crier();
    a2.crier(); // Appel dynamique
    c.crier();
}