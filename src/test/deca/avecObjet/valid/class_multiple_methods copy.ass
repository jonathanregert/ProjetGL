; start main program
; Passe1 table de méthode : C base=3(GB) taille=5
	TSTO #7	; Main Program
	BOV pile_pleine
	ADDSP #7
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.C.f, R0
	STORE R0, 5(GB)
	LOAD code.C.g, R0
	STORE R0, 6(GB)
	LOAD code.C.h, R0
	STORE R0, 7(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.C:
; init.C (this = -2(LB))
	RTS
; Code des méthodes de la classe C
code.C.f:
; Méthode C.f
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD #1, R1
	LOAD R1, R0
	BRA fin.C.f
fin.C.f:
	POP R3
	RTS
code.C.g:
; Méthode C.g
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD #0x1.9p3, R1
	LOAD R1, R0
	BRA fin.C.g
fin.C.g:
	POP R3
	RTS
code.C.h:
; Méthode C.h
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD #1, R1
	LOAD R1, R0
	BRA fin.C.h
fin.C.h:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
; end main program
