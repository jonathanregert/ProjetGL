; start main program
; Passe1 table de méthode : T base=3(GB) taille=2
; Passe1 table de méthode : U base=5(GB) taille=3
	TSTO #7	; Main Program
	BOV pile_pleine
	ADDSP #7
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LEA 3(GB), R0
	STORE R0, 5(GB)
	LOAD 4(GB), R0
	STORE R0, 6(GB)
	LOAD code.U.incr, R0
	STORE R0, 7(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.T:
; init.T (this = -2(LB))
	TSTO #2
	BOV pile_pleine
	PUSH R3
	LOAD -2(LB), R2
	PUSH R2
	LOAD #1, R3
	POP R2
	STORE R3, 1(R2)
	POP R3
	RTS
init.U:
; init.U (this = -2(LB))
	TSTO #2
	BOV pile_pleine
	PUSH R3
	LOAD -2(LB), R0
	PUSH R0
	BSR init.T
	POP R0
	POP R3
	RTS
; Code des méthodes de la classe T
; Code des méthodes de la classe U
code.U.incr:
; Méthode U.incr
	TSTO #2
	BOV pile_pleine
	PUSH R3
	LOAD -2(LB), R2
	LOAD 1(R2), R1
	PUSH R1
	LOAD #1, R3
	POP R2
	ADD R3, R2
	BOV overflow_arith
	LOAD R2, R1
	LOAD -2(LB), R2
	STORE R1, 1(R2)
	BRA fin.U.incr
fin.U.incr:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
; end main program
