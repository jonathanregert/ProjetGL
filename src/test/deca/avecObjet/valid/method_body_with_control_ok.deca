// Description :
//    Corps de méthode contenant if et while.
//
// Resultats :
//    2

class A {
    int f() {
        int i = 0;
        while (i < 2) {
            i = i + 1;
        }
        if (i == 2) {
            return i;
        }
        return 0;
    }
}

{
    A a = new A();
    println(a.f());
}

