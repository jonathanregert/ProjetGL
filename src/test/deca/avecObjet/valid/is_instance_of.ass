; start main program
; Passe1 table de méthode : A base=3(GB) taille=2
; Passe1 table de méthode : B base=5(GB) taille=2
; Beginning of main instructions:
	TSTO #8	; Main Program
	BOV pile_pleine
	ADDSP #8
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LEA 3(GB), R0
	STORE R0, 5(GB)
	LOAD 4(GB), R0
	STORE R0, 6(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	NEW #1, R3
	BOV tas_plein
	LEA 3(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.A
	POP R3
	STORE R3, 7(GB)
	NEW #1, R3
	BOV tas_plein
	LEA 5(GB), R0
	STORE R0, 0(R3)
	PUSH R3
	BSR init.B
	POP R3
	STORE R3, 8(GB)
	LOAD 8(GB), R1
	CMP #null, R1
	BEQ instanceof_false_0
	LOAD 0(R1), R1
instanceof_loop_0:
	CMP #null, R1
	BEQ instanceof_false_0
	CMP 3(GB), R1
	BEQ instanceof_true_0
	LOAD 0(R1), R1
	BRA instanceof_loop_0
instanceof_true_0:
	LOAD #1, R1
	BRA instanceof_end_0
instanceof_false_0:
	LOAD #0, R1
instanceof_end_0:
	WINT
	WNL
	LOAD 7(GB), R1
	CMP #null, R1
	BEQ instanceof_false_1
	LOAD 0(R1), R1
instanceof_loop_1:
	CMP #null, R1
	BEQ instanceof_false_1
	CMP 5(GB), R1
	BEQ instanceof_true_1
	LOAD 0(R1), R1
	BRA instanceof_loop_1
instanceof_true_1:
	LOAD #1, R1
	BRA instanceof_end_1
instanceof_false_1:
	LOAD #0, R1
instanceof_end_1:
	WINT
	WNL
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.A:
; init.A (this = -2(LB))
	RTS
init.B:
; init.B (this = -2(LB))
	RTS
; Code des méthodes de la classe A
; Code des méthodes de la classe B
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
tas_plein:
	WSTR "Erreur : allocation impossible, tas plein"
	WNL
	ERROR
; end main program
