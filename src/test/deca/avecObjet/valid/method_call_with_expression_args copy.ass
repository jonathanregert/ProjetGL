; start main program
; Passe1 table de méthode : Y base=3(GB) taille=4
	TSTO #6	; Main Program
	BOV pile_pleine
	ADDSP #6
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.Y.f, R0
	STORE R0, 5(GB)
	LOAD code.Y.test, R0
	STORE R0, 6(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.Y:
; init.Y (this = -2(LB))
	RTS
; Code des méthodes de la classe Y
code.Y.f:
; Méthode Y.f
	TSTO #2
	BOV pile_pleine
	PUSH R3
	LOAD -3(LB), R1
	PUSH R1
	LOAD -4(LB), R3
	POP R2
	ADD R3, R2
	BOV overflow_arith
	LOAD R2, R1
	LOAD R1, R0
	BRA fin.Y.f
fin.Y.f:
	POP R3
	RTS
code.Y.test:
; Méthode Y.test
	TSTO #5
	BOV pile_pleine
	PUSH R3
	ADDSP #3
	LOAD -2(LB), R1
	STORE R1, 0(SP)
	LOAD #1, R1
	PUSH R1
	LOAD #2, R3
	POP R2
	ADD R3, R2
	BOV overflow_arith
	LOAD R2, R1
	STORE R1, -1(SP)
	LOAD #3, R1
	PUSH R1
	LOAD #2, R3
	POP R2
	MUL R3, R2
	BOV overflow_arith
	LOAD R2, R1
	STORE R1, -2(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #3
	LOAD R0, R1
	LOAD R1, R0
	BRA fin.Y.test
fin.Y.test:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
dereferencement_null:
	WSTR "Erreur : dereferencement de null"
	WNL
	ERROR
; end main program
