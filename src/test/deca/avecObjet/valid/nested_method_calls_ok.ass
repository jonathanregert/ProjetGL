; start main program
; Passe1 table de méthode : AA base=3(GB) taille=5
	TSTO #7	; Main Program
	BOV pile_pleine
	ADDSP #7
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.AA.f, R0
	STORE R0, 5(GB)
	LOAD code.AA.g, R0
	STORE R0, 6(GB)
	LOAD code.AA.h, R0
	STORE R0, 7(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.AA:
; init.AA (this = -2(LB))
	RTS
; Code des méthodes de la classe AA
code.AA.f:
; Méthode AA.f
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD #1, R1
	LOAD R1, R0
	BRA fin.AA.f
fin.AA.f:
	POP R3
	RTS
code.AA.g:
; Méthode AA.g
	TSTO #2
	BOV pile_pleine
	PUSH R3
	ADDSP #1
	LOAD -2(LB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #1
	LOAD R0, R1
	PUSH R1
	LOAD #2, R3
	POP R2
	ADD R3, R2
	BOV overflow_arith
	LOAD R2, R1
	LOAD R1, R0
	BRA fin.AA.g
fin.AA.g:
	POP R3
	RTS
code.AA.h:
; Méthode AA.h
	TSTO #3
	BOV pile_pleine
	PUSH R3
	ADDSP #1
	LOAD -2(LB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 3(R2)
	SUBSP #1
	LOAD R0, R1
	PUSH R1
	ADDSP #1
	LOAD -2(LB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #1
	LOAD R0, R1
	LOAD R1, R3
	POP R2
	ADD R3, R2
	BOV overflow_arith
	LOAD R2, R1
	LOAD R1, R0
	BRA fin.AA.h
fin.AA.h:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
overflow_arith:
	WSTR "Erreur : overflow_arithmetique"
	WNL
	ERROR
dereferencement_null:
	WSTR "Erreur : dereferencement de null"
	WNL
	ERROR
; end main program
