// Description :
//    Appels mutuels entre deux méthodes (récursivité croisée).
//
// Resultats :
//    Affiche : 0

class A {
    int f(int n) {
        if (n == 0) {
            return 0;
        }
        return g(n - 1);
    }

    int g(int n) {
        return f(n);
    }
}

{
    A a = new A();
    println(a.f(2));
}

