; start main program
; Passe1 table de méthode : S base=3(GB) taille=4
	TSTO #6	; Main Program
	BOV pile_pleine
	ADDSP #6
; --------------------------------------------------
; Construction des tables des methodes
; --------------------------------------------------
	LOAD #null, R0
	STORE R0, 1(GB)
	LOAD code.Object.equals, R0
	STORE R0, 2(GB)
	LEA 1(GB), R0
	STORE R0, 3(GB)
	LOAD 2(GB), R0
	STORE R0, 4(GB)
	LOAD code.S.f, R0
	STORE R0, 5(GB)
	LOAD code.S.test, R0
	STORE R0, 6(GB)
; --------------------------------------------------
; Code du programme principal
; --------------------------------------------------
	HALT
code.Object.equals:
	LOAD -2(LB), R0
	CMP -3(LB), R0
	BEQ Object.equals.true
	LOAD #0, R0
	BRA Object.equals.end
Object.equals.true:
	LOAD #1, R0
Object.equals.end:
	RTS
init.S:
; init.S (this = -2(LB))
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD -2(LB), R2
	LOAD #0, R0
	STORE R0, 1(R2)
	POP R3
	RTS
; Code des méthodes de la classe S
code.S.f:
; Méthode S.f
	TSTO #1
	BOV pile_pleine
	PUSH R3
	LOAD #5, R1
	LOAD R1, R0
	BRA fin.S.f
fin.S.f:
	POP R3
	RTS
code.S.test:
; Méthode S.test
	TSTO #2
	BOV pile_pleine
	PUSH R3
	ADDSP #1
	LOAD -2(LB), R1
	STORE R1, 0(SP)
	LOAD 0(SP), R2
	CMP #null, R2
	BEQ dereferencement_null
	LOAD 0(R2), R2
	BSR 2(R2)
	SUBSP #1
	LOAD R0, R1
	LOAD -2(LB), R2
	STORE R1, 1(R2)
	BRA fin.S.test
fin.S.test:
	POP R3
	RTS
; Message d'erreurs
pile_pleine:
	WSTR "Erreur : debordement de pile"
	WNL
	ERROR
dereferencement_null:
	WSTR "Erreur : dereferencement de null"
	WNL
	ERROR
; end main program
